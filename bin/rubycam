#!/usr/bin/env ruby
# Launch the Rubycam viewer.
#
#   bin/rubycam                  # first camera at /dev/video0
#   bin/rubycam /dev/video2      # explicit device node
#   bin/rubycam 'OBSBOT Tiny 2'  # find by card/bus name
#
# Needs the project dev shell for the GTK libs (direnv activates it, or
# run `nix develop` first).
ENV['BUNDLE_GEMFILE'] ||= File.expand_path('../Gemfile', __dir__)
require 'bundler/setup'
load File.expand_path('../app/camera_app.rb', __dir__)
