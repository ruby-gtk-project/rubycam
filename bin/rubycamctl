#!/usr/bin/env ruby
# Command-line companion to the Rubycam GTK viewer.
#
#   bin/rubycamctl                       # list commands
#   bin/rubycamctl status                # OBSBOT sleep/AI/HDR state
#   bin/rubycamctl wake                  # wake from privacy sleep
#   bin/rubycamctl track upper_body      # AI tracking mode
#   bin/rubycamctl set zoom_absolute 50  # any V4L2 control
#
# Needs only Ruby + the dry-cli gem (no GTK); the project dev shell
# provides both (direnv activates it, or run `nix develop` first).
ENV['BUNDLE_GEMFILE'] ||= File.expand_path('../Gemfile', __dir__)
require 'bundler/setup'
require_relative '../lib/rubycam/cli'
Dry::CLI.new(Rubycam::CLI::Commands).call
